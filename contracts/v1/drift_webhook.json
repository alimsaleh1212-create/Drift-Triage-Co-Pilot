{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DriftWebhookPayload",
  "description": "v1 contract: model service → agent on drift severity change",
  "type": "object",
  "required": [
    "version",
    "report_id",
    "model_name",
    "model_version",
    "severity",
    "psi_results",
    "chi2_results",
    "output_drift",
    "timestamp"
  ],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "report_id": { "type": "string", "minLength": 1 },
    "model_name": { "type": "string", "minLength": 1 },
    "model_version": { "type": "integer", "minimum": 1 },
    "severity": { "type": "string", "enum": ["low", "medium", "high"] },
    "psi_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["feature", "psi", "severity"],
        "properties": {
          "feature": { "type": "string" },
          "psi": { "type": "number", "minimum": 0 },
          "severity": { "type": "string", "enum": ["low", "medium", "high"] }
        }
      }
    },
    "chi2_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["feature", "statistic", "p_value", "severity"],
        "properties": {
          "feature": { "type": "string" },
          "statistic": { "type": "number", "minimum": 0 },
          "p_value": { "type": "number", "minimum": 0, "maximum": 1 },
          "severity": { "type": "string", "enum": ["low", "medium", "high"] }
        }
      }
    },
    "output_drift": {
      "type": "object",
      "required": ["psi", "severity"],
      "properties": {
        "psi": { "type": "number", "minimum": 0 },
        "severity": { "type": "string", "enum": ["low", "medium", "high"] }
      }
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "window_size": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
