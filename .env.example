# ╔══════════════════════════════════════════════════════════════════════╗
# ║  Drift Triage Co-Pilot — Environment Variables                      ║
# ║  Copy to .env:  cp .env.example .env                               ║
# ╚══════════════════════════════════════════════════════════════════════╝
#
# Setup:
#   1.  cp .env.example .env
#   2.  Edit .env — fill in the REQUIRED secrets (marked ← CHANGE ME)
#   3.  docker compose up -d
#
# For production, migrate secrets to HashiCorp Vault — see DECISIONS.md.
# .env is in .gitignore. Never commit real secrets.

# ═════════════════════════════════════════════════════════════════════════
#  REQUIRED — Must be set before running
# ═════════════════════════════════════════════════════════════════════════

# ── Secrets ──────────────────────────────────────────────────────────────
GOOGLE_API_KEY=changeme                           # ← CHANGE ME: your Google AI API key
POSTGRES_PASSWORD=changeme                        # ← CHANGE ME: a real password for Postgres
PROMOTION_API_KEY=changeme_changeme_ch            # ← CHANGE ME: min 16 chars, internal key for /promotion/promote

# ═════════════════════════════════════════════════════════════════════════
#  OPTIONAL — Sensible defaults for local development
# ═════════════════════════════════════════════════════════════════════════

# ── Postgres ─────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=drift_triage
POSTGRES_DB=drift_triage

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── MLflow ───────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── LLM — Primary: Gemini ────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash

# ── LLM — Fallback: Ollama ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# ── ML / Drift thresholds ────────────────────────────────────────────────
RANDOM_STATE=42
TEST_SIZE=0.2
VAL_SIZE=0.2
MIN_RECALL=0.75
DRIFT_PSI_WARN=0.1
DRIFT_PSI_HIGH=0.25
DRIFT_CHI2_ALPHA=0.05
DRIFT_WINDOW_SIZE=500

# ── Queue (arq) ──────────────────────────────────────────────────────────
REDIS_QUEUE_NAME=drift_actions
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY_BASE=1.0

# ── Internal service URLs (Docker networking) ─────────────────────────────
SERVICE_URL=http://service:8000
AGENT_URL=http://agent:8001

# ═════════════════════════════════════════════════════════════════════════
#  INFRASTRUCTURE — Used by docker-compose.yaml service containers
# ═════════════════════════════════════════════════════════════════════════

# ── pgAdmin (optional dev tool) ──────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@drift-triage.local
PGADMIN_DEFAULT_PASSWORD=changeme

# ── MinIO (S3-compatible artifact store for MLflow) ───────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MLFLOW_BUCKET_NAME=mlflow