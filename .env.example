# Drift Triage Co-Pilot — environment variables
#
# ONLY these three Vault AppRole credentials come from the environment.
# All other secrets (google_api_key, postgres_password, promotion_api_key)
# are fetched from HashiCorp Vault at startup.
#
# Setup:
#   cp .env.example .env
#   docker compose up -d          # Vault starts; vault-init seeds secrets
#   # Edit .env: fill VAULT_ROLE_ID and VAULT_SECRET_ID from vault-init output
#   docker compose restart service agent worker

VAULT_ADDR=http://localhost:8200
VAULT_ROLE_ID=changeme-role-id
VAULT_SECRET_ID=changeme-secret-id
